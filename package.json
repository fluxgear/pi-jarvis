{
  "name": "pi-jarvis",
  "version": "1.2.0",
  "description": "A /jarvis side-conversation overlay extension for Pi.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluxgear/pi-jarvis.git"
  },
  "homepage": "https://github.com/fluxgear/pi-jarvis#readme",
  "bugs": {
    "url": "https://github.com/fluxgear/pi-jarvis/issues"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "extension",
    "tui",
    "overlay",
    "assistant"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepack": "npm run build",
    "test": "npm run check && node --import tsx test/jarvis.test.ts"
  },
  "dependencies": {
    "pi-mcp-adapter": "^2.2.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
